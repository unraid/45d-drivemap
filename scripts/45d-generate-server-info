#!/usr/bin/php
<?php
// Ensures /var/local/45d/server_info.json exists on Unraid.
// Priority: vendor-provided file -> vendor server_identifier -> local inference.
$output_dir = getenv('DRIVEMAP_OUTPUT_DIR') ?: '/var/local/45d';
$output_file = getenv('DRIVEMAP_SERVER_INFO_OUTPUT') ?: ($output_dir . '/server_info.json');
$source_file = getenv('DRIVEMAP_SERVER_INFO_INPUT') ?: '/etc/45drives/server_info/server_info.json';
$vendor_server_identifier = getenv('DRIVEMAP_VENDOR_SERVER_IDENTIFIER') ?: '/opt/45drives/tools/server_identifier';
$alias_file = getenv('DRIVEMAP_ALIAS_FILE') ?: '/etc/vdev_id.conf';
$force_model = getenv('DRIVEMAP_SERVER_MODEL') ?: '';
$force_chassis = getenv('DRIVEMAP_CHASSIS_SIZE') ?: '';
$force_alias = getenv('DRIVEMAP_ALIAS_STYLE') ?: '';
$force_serial = getenv('DRIVEMAP_SERVER_SERIAL') ?: '';
$force_prefix = getenv('DRIVEMAP_SERVER_PREFIX') ?: '';
$product_name_override = getenv('DRIVEMAP_PRODUCT_NAME') ?: '';
$board_name_override = getenv('DRIVEMAP_BOARD_NAME') ?: '';
$board_vendor_override = getenv('DRIVEMAP_BOARD_VENDOR') ?: '';
$lspci_verbose_override = getenv('DRIVEMAP_LSPCI_VERBOSE') ?: '';
$log_file = getenv('DRIVEMAP_LOG_FILE') ?: ($output_dir . '/drivemap.log');

@mkdir($output_dir, 0755, true);

function log_line($path, $message)
{
  @file_put_contents($path, gmdate('c') . " " . $message . "\n", FILE_APPEND);
}

function read_first_value($paths)
{
  foreach ($paths as $path) {
    if (is_file($path)) {
      $value = trim((string)@file_get_contents($path));
      if ($value !== '' && $value !== 'None') {
        return $value;
      }
    }
  }
  return '';
}

function alias_templates()
{
  // Layout templates used to infer alias style/chassis from alias counts.
  return [
    'H16' => [
      'AV15' => [23],
      'Q30' => [15, 23],
      'S45' => [15, 15, 23],
      'XL60' => [15, 15, 15, 23],
    ],
    'H32' => [
      'Q30' => [15, 32],
      'S45' => [15, 15, 32],
      'XL60' => [15, 15, 15, 32],
    ],
    'STORINATOR' => [
      'AV15' => [15],
      'Q30' => [15, 15],
      'S45' => [15, 15, 15],
      'XL60' => [15, 15, 15, 15],
      'C8' => [4, 4],
      'MI4' => [4],
    ],
    'HOMELAB' => [
      'HL4' => [4],
      'HL8' => [4, 4],
      'HL15' => [15],
      'HL15_BEAST' => [23],
    ],
    'PROFESSIONAL' => [
      'PRO4' => [4],
      'PRO8' => [4, 4],
      'PRO15' => [15],
    ],
    'F8' => [
      'F8X1' => [20],
      'F8X2' => [20, 20],
      'F8X3' => [20, 20, 20],
    ],
    'STUDIO' => [
      'STUDIO8' => [4, 4],
    ],
    'BYPATH' => [
      'VM2' => [2],
    ],
  ];
}

function alias_summary($alias_file)
{
  if (!is_file($alias_file)) {
    return ['rows' => [], 'total' => 0];
  }
  $lines = file($alias_file, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
  if (!is_array($lines)) {
    return ['rows' => [], 'total' => 0];
  }

  $counts = [];
  $total = 0;
  foreach ($lines as $line) {
    $line = trim($line);
    if ($line === '' || strpos($line, '#') === 0) {
      continue;
    }
    if (preg_match('/^alias\s+(\d+)-(\d+)\s+(\S+)/', $line, $matches)) {
      $card = (int)$matches[1];
      if (!isset($counts[$card])) {
        $counts[$card] = 0;
      }
      $counts[$card]++;
      $total++;
    }
  }
  ksort($counts);
  return ['rows' => array_values($counts), 'total' => $total];
}

function prefix_hint($prefix)
{
  $prefix = strtolower($prefix);
  if ($prefix === 'homelab') {
    return 'HOMELAB';
  }
  if ($prefix === 'professional') {
    return 'PROFESSIONAL';
  }
  if ($prefix === 'studio') {
    return 'STUDIO';
  }
  return '';
}

function infer_layout_from_aliases($alias_file, $prefix)
{
  // First try exact row-shape matching, then fall back to total-drive heuristics.
  $summary = alias_summary($alias_file);
  $rows = $summary['rows'];
  $total = $summary['total'];
  if (!$rows) {
    return ['style' => '', 'chassis' => ''];
  }

  $templates = alias_templates();
  $candidates = [];
  foreach ($templates as $style => $chassis_map) {
    foreach ($chassis_map as $chassis => $lengths) {
      if ($lengths === $rows) {
        $candidates[] = ['style' => $style, 'chassis' => $chassis];
      }
    }
  }

  if ($candidates) {
    $hint = prefix_hint($prefix);
    if ($hint !== '') {
      foreach ($candidates as $candidate) {
        if ($candidate['style'] === $hint) {
          return $candidate;
        }
      }
    }
    foreach ($candidates as $candidate) {
      if ($candidate['style'] === 'STORINATOR') {
        return $candidate;
      }
    }
    return $candidates[0];
  }

  $simple_map = [
    2 => ['BYPATH', 'VM2'],
    8 => ['F8', 'F8X1'],
    15 => ['STORINATOR', 'AV15'],
    16 => ['STORINATOR', 'Q30'],
    20 => ['F8', 'F8X1'],
    23 => ['H16', 'AV15'],
    30 => ['STORINATOR', 'Q30'],
    32 => ['H32', 'Q30'],
    45 => ['STORINATOR', 'S45'],
    60 => ['STORINATOR', 'XL60'],
  ];
  if (isset($simple_map[$total])) {
    return ['style' => $simple_map[$total][0], 'chassis' => $simple_map[$total][1]];
  }

  return ['style' => '', 'chassis' => ''];
}

function infer_prefix($product_name)
{
  $product_name = strtolower($product_name);
  $prefixes = [
    'mw34-sp0-00' => 'HomeLab',
    'stornado' => 'Stornado',
    'proxinator' => 'Proxinator',
    'destroyinator' => 'Destroyinator',
    'homelab' => 'HomeLab',
    'professional' => 'Professional',
    'studio' => 'Studio',
  ];
  foreach ($prefixes as $needle => $prefix) {
    if (strpos($product_name, $needle) !== false) {
      return $prefix;
    }
  }
  return 'Storinator';
}

function lspci_verbose_output($override)
{
  if ($override !== '') {
    return $override;
  }
  $output = shell_exec('lspci -d 1000:* -vv 2>/dev/null');
  return is_string($output) ? $output : '';
}

function detect_hbas($lspci_output)
{
  if (!is_string($lspci_output) || trim($lspci_output) === '') {
    return [];
  }

  $hba_models = [
    'SAS9305-16i' => 16,
    'SAS9305-24i' => 24,
    'HBA 9405W-16i' => 16,
    'HBA 9400-16i' => 16,
    '9600-24i' => 24,
    '9600-16i' => 16,
    '9660-16i' => 16,
    '9361-16i' => 16,
    '9361-24i' => 24,
  ];
  $hba_drivers = [
    'SAS9305-16i' => 'mpt3sas',
    'SAS9305-24i' => 'mpt3sas',
    'HBA 9405W-16i' => 'mpt3sas',
    'HBA 9400-16i' => 'mpt3sas',
    '9600-24i' => 'mpi3mr',
    '9600-16i' => 'mpi3mr',
    '9660-16i' => 'mpi3mr',
    '9361-16i' => 'megaraid_sas',
    '9361-24i' => 'megaraid_sas',
  ];
  $hba_adapters = [
    'SAS9305-16i' => 'SAS3224 PCI-Express Fusion-MPT SAS-3',
    'SAS9305-24i' => 'SAS3224 PCI-Express Fusion-MPT SAS-3',
    'HBA 9405W-16i' => 'SAS3616 Fusion-MPT Tri-Mode I/O Controller Chip (IOC)',
    'HBA 9400-16i' => 'SAS3416 Fusion-MPT Tri-Mode I/O Controller Chip (IOC)',
    '9600-24i' => 'Fusion-MPT 24GSAS/PCIe SAS40xx',
    '9600-16i' => 'Fusion-MPT 24GSAS/PCIe SAS40xx',
    '9660-16i' => 'Fusion-MPT 24GSAS/PCIe SAS40xx',
    '9361-16i' => 'MegaRAID SAS-3 3316',
    '9361-24i' => 'MegaRAID SAS-3 3316',
  ];

  $pattern = '/^((?:[0-9A-Fa-f]{4}:)?[0-9A-Fa-f]{2}:[0-9A-Fa-f]{2}\.[0-9A-Fa-f]).*\n(?:^\t.*\n)*^\tSubsystem: .*?(9600-16i|9600-24i|SAS9305-16i|SAS9305-24i|HBA 9405W-16i|9361-16i|HBA 9400-16i|9361-24i|9660-16i).*$/m';
  if (!preg_match_all($pattern, $lspci_output, $matches, PREG_SET_ORDER)) {
    return [];
  }

  $hbas = [];
  foreach ($matches as $index => $match) {
    $model = $match[2];
    $bus = $match[1];
    if (strpos($bus, '0000:') !== 0) {
      $bus = '0000:' . $bus;
    }
    $hbas[] = [
      'Model' => $model,
      'Adapter' => $hba_adapters[$model] ?? $model,
      'Bus Address' => $bus,
      'Drive Connections' => $hba_models[$model] ?? 0,
      'Kernel Driver' => $hba_drivers[$model] ?? '?',
      'Ctl' => $index,
      'Firmware Version' => '?',
      'Driver Version' => '?',
      'Driver Name' => $hba_drivers[$model] ?? '?',
    ];
  }

  return $hbas;
}

function count_hbas_by_connections($hbas, $connections)
{
  $count = 0;
  foreach ($hbas as $hba) {
    if ((int)($hba['Drive Connections'] ?? 0) === (int)$connections) {
      $count++;
    }
  }
  return $count;
}

function hardware_profile($product_name, $board_name, $hbas)
{
  $names = array_filter([$product_name, $board_name], fn($value) => is_string($value) && $value !== '');
  foreach ($names as $name) {
    if ($name === 'MW34-SP0-00' && count_hbas_by_connections($hbas, 16) === 1 && count_hbas_by_connections($hbas, 24) === 0) {
      return [
        'prefix' => 'HomeLab',
        'style' => 'HOMELAB',
        'chassis' => 'HL15',
        'model' => 'Unraid >< 45Homelab X-15',
      ];
    }
  }
  return null;
}

function model_from_parts($prefix, $style, $chassis)
{
  if ($chassis === '' || $chassis === '?') {
    return $prefix;
  }
  if ($style === 'H16' || $style === 'H32') {
    return $prefix . '-' . $style . '-' . $chassis;
  }
  return $prefix . '-' . $chassis;
}

function canvas_model_from_server_info($server_info)
{
  if (!is_array($server_info)) {
    return '';
  }
  if (isset($server_info['Canvas Model']) && is_string($server_info['Canvas Model']) && $server_info['Canvas Model'] !== '') {
    return $server_info['Canvas Model'];
  }

  $model = isset($server_info['Model']) && is_string($server_info['Model']) ? $server_info['Model'] : '';
  $style = isset($server_info['Alias Style']) && is_string($server_info['Alias Style']) ? strtoupper($server_info['Alias Style']) : '';
  $chassis = isset($server_info['Chassis Size']) && is_string($server_info['Chassis Size']) ? strtoupper($server_info['Chassis Size']) : '';

  if ($style !== '' && $chassis !== '' && $chassis !== '?') {
    $prefix = '';
    if (preg_match('/\b(Storinator|Stornado|HomeLab|Professional|Proxinator|Studio)\b/i', $model, $matches)) {
      $prefix_map = [
        'storinator' => 'Storinator',
        'stornado' => 'Stornado',
        'homelab' => 'HomeLab',
        'professional' => 'Professional',
        'proxinator' => 'Proxinator',
        'studio' => 'Studio',
      ];
      $prefix = $prefix_map[strtolower($matches[1])] ?? $matches[1];
    }
    if ($prefix === '') {
      $prefix = [
        'HOMELAB' => 'HomeLab',
        'PROFESSIONAL' => 'Professional',
        'STUDIO' => 'Studio',
        'BYPATH' => strpos($chassis, 'VM') === 0 ? 'Proxinator' : 'Storinator',
      ][$style] ?? 'Storinator';
    }
    return model_from_parts($prefix, $style, $chassis);
  }

  return $model !== '' ? $model : '';
}

function copy_server_info_with_canvas_model($source_file, $output_file)
{
  $contents = @file_get_contents($source_file);
  $server_info = is_string($contents) ? json_decode($contents, true) : null;
  if (!is_array($server_info)) {
    return @copy($source_file, $output_file);
  }

  $server_info['Canvas Model'] = canvas_model_from_server_info($server_info);
  return file_put_contents($output_file, json_encode($server_info, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n") !== false;
}

if (is_file($source_file)) {
  // Prefer exact vendor output when present.
  copy_server_info_with_canvas_model($source_file, $output_file);
  log_line($log_file, 'server_info copied from ' . $source_file);
  exit(0);
}

$vendor_output = [];
$vendor_code = 0;
if (is_executable($vendor_server_identifier)) {
  // If vendor tool can generate the source file, consume it directly.
  exec(escapeshellarg($vendor_server_identifier) . ' 2>&1', $vendor_output, $vendor_code);
  if ($vendor_code === 0 && is_file($source_file)) {
    copy_server_info_with_canvas_model($source_file, $output_file);
    log_line($log_file, 'server_info copied after server_identifier run');
    exit(0);
  }
  if ($vendor_output) {
    log_line($log_file, 'server_identifier output: ' . implode(' | ', $vendor_output));
  }
}

$product_name = $product_name_override !== '' ? $product_name_override : read_first_value([
  '/sys/class/dmi/id/product_name',
  '/sys/class/dmi/id/board_name',
]);
$board_name = $board_name_override !== '' ? $board_name_override : read_first_value([
  '/sys/class/dmi/id/board_name',
  '/sys/class/dmi/id/product_name',
]);
$board_vendor = $board_vendor_override !== '' ? $board_vendor_override : read_first_value([
  '/sys/class/dmi/id/board_vendor',
  '/sys/class/dmi/id/sys_vendor',
]);
$serial = $force_serial !== '' ? $force_serial : read_first_value([
  '/sys/class/dmi/id/product_serial',
  '/sys/class/dmi/id/chassis_serial',
  '/sys/class/dmi/id/board_serial',
]);
$hbas = detect_hbas(lspci_verbose_output($lspci_verbose_override));
$prefix = $force_prefix !== '' ? $force_prefix : infer_prefix($product_name);
$layout = infer_layout_from_aliases($alias_file, $prefix);
$profile = hardware_profile($product_name, $board_name, $hbas);

$chassis = $force_chassis !== '' ? $force_chassis : ($layout['chassis'] !== '' ? $layout['chassis'] : ($profile['chassis'] ?? '?'));
$alias_style = $force_alias !== '' ? strtoupper($force_alias) : ($layout['style'] !== '' ? $layout['style'] : ($profile['style'] ?? 'STORINATOR'));
$chassis = strtoupper($chassis);

$model = $force_model !== '' ? $force_model : ($profile['model'] ?? model_from_parts($prefix, $alias_style, $chassis));

$server_info = [
  // Keep output compatible with the embedded 45Drives frontend contract.
  'Model' => $model !== '' ? $model : '?',
  'Canvas Model' => model_from_parts($prefix, $alias_style, $chassis),
  'Chassis Size' => $chassis !== '' ? $chassis : '?',
  'Alias Style' => $alias_style !== '' ? $alias_style : '?',
  'Serial' => $serial !== '' ? $serial : '?',
  'HBA' => $hbas,
  'Motherboard' => [
    'Manufacturer' => $board_vendor !== '' ? $board_vendor : '?',
    'Product Name' => $board_name !== '' ? $board_name : '?',
    'Serial Number' => $serial !== '' ? $serial : '?',
  ],
];

file_put_contents($output_file, json_encode($server_info, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n");
log_line($log_file, 'server_info generated');
